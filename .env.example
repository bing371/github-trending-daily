# =====================================================================
#  GitHub Trending Daily — local credentials template
# =====================================================================
#  Copy this file to `.env` and fill in your own keys. NEVER commit
#  the real `.env` to git — `.gitignore` already excludes it.
#
#  Apply changes: just save the file. The web UI hot-reloads on next
#  request, and the next scheduled run picks up new values.
# =====================================================================

# ---- Translation (Baidu Fanyi) ----------------------------------------
# Free tier: https://api.fanyi.baidu.com/  (注册 → 开发者信息)
# Required. Used to translate GitHub project descriptions to Chinese.
BAIDU_APPID=your_baidu_appid_here
BAIDU_TRANSLATE_KEY=your_baidu_translate_key_here

# ---- Agent API (OpenAI-compatible chat completions) -------------------
# Pick one provider and fill in the matching fields. The web UI
# (⚙️ 设置 → 🤖 agent API) lets you switch providers without editing
# this file by hand.
#
# Presets:
#   minimax      api.minimaxi.com/v1                          MiniMax-M3
#   deepseek     api.deepseek.com/v1                          deepseek-chat
#   moonshot     api.moonshot.cn/v1                           moonshot-v1-8k
#   zhipu        open.bigmodel.cn/api/paas/v4                 glm-4-flash
#   qwen         dashscope.aliyuncs.com/compatible-mode/v1    qwen-turbo
#   baiduqianfan qianfan.baidubce.com/v2                      ernie-speed
#   yi           api.lingyiwanwu.com/v1                       yi-large
#   openai       api.openai.com/v1                            gpt-4o-mini
#   ollama       http://127.0.0.1:11434/v1                    llama3.1
#   openrouter   openrouter.ai/api/v1                         openai/gpt-4o-mini
#   custom       <your own OpenAI-compatible endpoint>        <your model>
AGENT_PROVIDER=minimax
AGENT_API_BASE=https://api.minimaxi.com/v1
AGENT_API_KEY=your_agent_api_key_here
AGENT_MODEL=MiniMax-M3

# ---- Backwards-compat alias -------------------------------------------
# Older versions read this directly. If AGENT_API_KEY above is empty,
# the server falls back to this. Safe to leave blank.
minimax_API_KEY=